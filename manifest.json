{
  "manifest_version": 3,
  "name": "Reset Lens",
  "version": "1.2",
  "description": "Translate reset times on Claude and Codex usage pages: countdowns become clock times, absolute times get a countdown.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/settings/usage*",
        "https://chatgpt.com/codex/cloud/settings/analytics*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
